{
  "name": "FreshCart - Checkout Success Rate Low",
  "rule_type_id": ".index-threshold",
  "consumer": "alerts",
  "schedule": {
    "interval": "1m"
  },
  "enabled": true,
  "tags": [
    "freshcart",
    "checkout",
    "conversion"
  ],
  "params": {
    "index": [
      "freshcart-metrics-checkout-1m"
    ],
    "timeField": "bucket_start",
    "aggType": "avg",
    "aggField": "checkout_success_rate",
    "groupBy": "all",
    "thresholdComparator": "<",
    "threshold": [
      0.9
    ],
    "timeWindowSize": 10,
    "timeWindowUnit": "m"
  },
  "actions": [
    {
      "group": "threshold met",
      "id": "__CONNECTOR_ID__",
      "params": {
        "level": "error",
        "message": "Checkout success rate dropped to {{context.value}} over the last 10 minutes."
      }
    }
  ]
}

